# ==============================================
# Docker Compose - Variáveis de Ambiente (exemplo)
# Copie para .env:  cp .env.example .env
# ==============================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=assistencia_auto
MYSQL_USER=assistencia
MYSQL_PASSWORD=assistencia123

# ---- Backend ----
JWT_SECRET=defina_uma_chave_secreta

# ---- Portas expostas no host ----
FRONTEND_PORT=3000
BACKEND_PORT=3001
# Se a 3306 já estiver em uso por outro MySQL local, troque para 3307 etc.
MYSQL_PORT=3306
