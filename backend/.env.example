# ==============================================
# Backend - Variáveis de Ambiente (exemplo)
# Copie para .env e ajuste os valores:  cp .env.example .env
# ==============================================

PORT=3001
NODE_ENV=development

# ---- Banco de Dados MySQL ----
# Docker Compose: use "mysql". Rodando o backend na máquina host: use "localhost".
DB_HOST=mysql
DB_PORT=3306
DB_USER=assistencia
DB_PASSWORD=assistencia123
DB_NAME=assistencia_auto

# ---- Autenticação ----
JWT_SECRET=defina_uma_chave_secreta

# ---- Frontend permitido no CORS ----
FRONTEND_URL=http://localhost:3000
